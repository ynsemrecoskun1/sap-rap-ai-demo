projection;
strict ( 2 );

define behavior for ZC_YAIPOHEADER alias poheader
use etag
{
  use create;
  use update;
  use delete;

  use action DeleteOrder;

  use association _Item { create; }
}

define behavior for ZC_YAIPOITEM alias poitem
use etag
{
  use update;
  use delete;

  use association _Header;
}
