unmanaged implementation in class zbp_r_yaipoheader unique;
strict ( 2 );
with unmanaged save;

define behavior for ZR_YAIPOHEADER alias poheader
lock master
authorization master ( global )
{
  field ( readonly ) PurchaseOrder;

  action DeleteOrder result [1] $self;

  association _Item;
}

define behavior for ZR_YAIPOITEM alias poitem
lock dependent by _Header
authorization dependent by _Header
{
  field ( readonly ) PurchaseOrder, PurchaseOrderItem;

  association _Header;
}
